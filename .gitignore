# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

.DS_Store

# project specific
.scratchpad
.env
.claude
# CLAUDE.md is committed (public guidance); local-only overrides are not:
CLAUDE.local.md

# Recorded benchmark runs (M4+) — example output, not source.
runs/

# mdbook outputs (scoped to the doc dirs — a bare `book/` also matches the
# example source dir crates/rlevo-examples/examples/book/)
docs/user-book/book/
docs/contributor-book/book/

# private specs, sessions, etc.
docs/.private/

# personal DRY scripts
scripts/
